// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id                  String   @id @default(cuid())
  name                String   @unique
  color               String? // Tailwind class or specific style
  users               User[]   @relation("UserTeam")
  fastestPitstopUsers User[]   @relation("FastestPitstop")
  drivers             Driver[]
}

model Driver {
  slug            String       @id // The ID from data.ts ("ver", etc)
  name            String
  number          Int
  country         String?
  active          Boolean      @default(true) // For individual races
  activeSeason    Boolean      @default(true) // For full season predictions
  teamId          String
  team            Team         @relation(fields: [teamId], references: [id])
  color           String?
  votes           Vote[]
  seasonVotes     SeasonVote[]
  favorited       User[]       @relation("FavoriteDriver")
  fastestLapUsers User[]       @relation("FastestLap")
  mostDotdUsers   User[]       @relation("MostDotd")
}

model User {
  id                   String               @id @default(cuid())
  username             String               @unique
  password             String // Hashed password
  name                 String?
  isAdmin              Boolean              @default(false)
  teamId               String?
  team                 Team?                @relation("UserTeam", fields: [teamId], references: [id])
  favoriteDriverId     String?
  favoriteDriver       Driver?              @relation("FavoriteDriver", fields: [favoriteDriverId], references: [slug])
  fastestLapDriverId   String?
  fastestLapDriver     Driver?              @relation("FastestLap", fields: [fastestLapDriverId], references: [slug])
  fastestPitstopTeamId String?
  fastestPitstopTeam   Team?                @relation("FastestPitstop", fields: [fastestPitstopTeamId], references: [id])
  mostDotdDriverId     String?
  mostDotdDriver       Driver?              @relation("MostDotd", fields: [mostDotdDriverId], references: [slug])
  mostDnfRange         String?
  firstRaceCollision   Boolean?
  firstRaceRain        Boolean?
  unlockedSeason       Boolean              @default(false)
  avatar               String? // URL to avatar image
  votes                Vote[]
  seasonVotes          SeasonVote[]
  raceScores           RaceScore[]
  raceExtraVotes       RaceExtraVote[]
  passwordResetTokens  PasswordResetToken[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [slug])
  raceRound String // Stores "season-position-X" or "race-Y-position-Z"
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([raceRound])
}

model SeasonVote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [slug])
  position  Int // 1-based position (1 = predicted champion)
  season    Int      @default(2026)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, position, season])
  @@unique([userId, driverId, season])
  @@index([userId, season])
}

model Race {
  id                   String          @id @default(cuid())
  round                Int             @unique
  name                 String
  location             String
  date                 DateTime
  circuitId            String?
  url                  String?
  country              String?
  trackImage           String?
  isTesting            Boolean         @default(false)
  completed            Boolean         @default(false)
  canceled             Boolean         @default(false)
  results              String[] // Array of driver slugs in finish order
  hasSprint            Boolean         @default(false)
  sprintDate           DateTime?
  sprintCompleted      Boolean         @default(false)
  sprintResults        String[] // Array of driver slugs in sprint finish order
  scores               RaceScore[]
  extraVotes           RaceExtraVote[]
  // Actual race extras (filled by admin when finishing race)
  actualDotd           String? // Driver slug - Driver of the Day
  actualDnfCount       Int? // Number of DNFs in the race
  actualFastestLap     String? // Driver slug - Fastest lap
  actualStartCollision Boolean? // Was there a collision at the start?
}

model RaceExtraVote {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  raceRound          Int
  race               Race     @relation(fields: [raceRound], references: [round], onDelete: Cascade)
  dotdDriverId       String? // Driver of the Day prediction
  dnfCount           Int? // Number of DNFs prediction
  fastestLapDriverId String? // Fastest lap driver prediction
  startCollision     Boolean? // Collision at start prediction
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, raceRound])
  @@index([userId])
  @@index([raceRound])
}

model RaceScore {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  raceRound          Int
  race               Race     @relation(fields: [raceRound], references: [round], onDelete: Cascade)
  isSprint           Boolean  @default(false)
  totalPoints        Int      @default(0)
  perfectPredictions Int      @default(0)
  details            Json? // Detailed breakdown of predictions vs results
  createdAt          DateTime @default(now())

  @@unique([userId, raceRound, isSprint])
  @@index([userId])
  @@index([raceRound])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
